# --- Serveur ---
# 3010 : 3001 est déjà occupé par un autre service du homelab (Caddy)
PORT=3010
HOST=0.0.0.0

# --- Base de données ---
DATABASE_URL=postgres://racontine:racontine@localhost:5433/racontine
# En prod (docker-compose.prod.yml) : mot de passe Postgres hors du compose.
POSTGRES_USER=racontine
POSTGRES_PASSWORD=change-me
POSTGRES_DB=racontine

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=change-me-openssl-rand-hex-32
# URL publique de l'API en prod (ex. https://racontine.exemple.fr)
BETTER_AUTH_URL=http://localhost:3010
# Origines autorisées (CORS + trustedOrigins), séparées par des virgules.
# En prod : le domaine public servi par le reverse proxy.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Passer à false une fois les comptes parent + co-parent créés.
SIGNUP_ENABLED=true

# --- Extraction VLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Modèle vision utilisé pour lire le carnet
VLM_MODEL=claude-sonnet-5

# --- Stockage des photos ---
UPLOADS_DIR=./uploads
