# --- Serveur ---
# 3010 : 3001 est déjà occupé par un autre service du homelab (Caddy)
PORT=3010
HOST=0.0.0.0

# --- Base de données ---
DATABASE_URL=postgres://racontine:racontine@localhost:5433/racontine
# En prod (docker-compose.prod.yml) : mot de passe Postgres hors du compose.
POSTGRES_USER=racontine
POSTGRES_PASSWORD=change-me
POSTGRES_DB=racontine

# --- Auth (Better Auth) ---
BETTER_AUTH_SECRET=change-me-openssl-rand-hex-32
# URL publique de l'API en prod (ex. https://racontine.exemple.fr)
BETTER_AUTH_URL=http://localhost:3010
# Origines autorisées (CORS + trustedOrigins), séparées par des virgules.
# En prod : le domaine public servi par le reverse proxy.
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Passer à false une fois les comptes parent + co-parent créés. Les proches
# invités se connectent par magic link, sans être bloqués par ce réglage.
SIGNUP_ENABLED=true

# --- Partage & invitations ---
# Base publique du front, pour construire les liens d'invitation et de magic
# link. Défaut : la 1re valeur de CORS_ORIGINS.
WEB_BASE_URL=http://localhost:5173
# Validité d'une invitation, en jours.
INVITATION_TTL_DAYS=14
# Optionnel : webhook (ntfy…) pour livrer les liens aux proches. Sans lui, les
# liens sont journalisés côté serveur et copiables depuis l'écran Partage.
# NOTIFY_WEBHOOK_URL=https://ntfy.exemple.fr/racontine

# --- Extraction VLM ---
ANTHROPIC_API_KEY=sk-ant-...
# Modèle vision utilisé pour lire le carnet
VLM_MODEL=claude-sonnet-5

# --- Stockage des photos ---
UPLOADS_DIR=./uploads

# --- Notifications aux proches ---
# URL publique du front (PWA), utilisée dans les liens des e-mails.
# Défaut : première origine CORS.
APP_URL=http://localhost:5173
# SMTP pour l'envoi des e-mails de notification. Si SMTP_HOST est vide, les
# e-mails sont désactivés (les notifications in-app fonctionnent quand même).
SMTP_HOST=
SMTP_PORT=587
# true pour SMTPS (port 465), false pour STARTTLS (port 587).
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Expéditeur affiché des e-mails.
MAIL_FROM=Racontine <no-reply@racontine.local>
